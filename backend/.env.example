# Core deployment settings
ENVIRONMENT=dev
BACKEND_PORT=8000
MONGO_URL=
DB_NAME=
SECRET_KEY=
# Comma-separated exact frontend origins; never use * with credential cookies.
ALLOWED_ORIGINS=http://localhost:5173

# Initial superadmin (required when seeding a new database)
SUPERADMIN_USERNAME=
SUPERADMIN_PASSWORD=
SUPERADMIN_EMAIL=

# Email provider connection
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional deployment-specific storage path
UPLOAD_DIR=uploads
