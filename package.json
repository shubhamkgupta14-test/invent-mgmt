{
  "name": "inventory-management",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/start.mjs development",
    "start:dev": "node scripts/start.mjs development",
    "start:test": "node scripts/start.mjs test",
    "start": "node scripts/start.mjs development",
    "start:prod": "node scripts/start.mjs production",
    "seed": "node scripts/python.mjs backend/scripts/seed.py --env dev",
    "seed:dev": "node scripts/python.mjs backend/scripts/seed.py --env dev",
    "seed:test": "node scripts/python.mjs backend/scripts/seed.py --env test",
    "seed:prod": "node scripts/python.mjs backend/scripts/seed.py --env prod",
    "test": "node scripts/check.mjs",
    "test:backend": "node scripts/python.mjs -m unittest discover -s test/backend -p test_*.py",
    "test:frontend": "npm --prefix frontend test",
    "lint": "npm --prefix frontend run lint",
    "build": "npm --prefix frontend run build:dev",
    "build:dev": "npm --prefix frontend run build:dev",
    "build:test": "npm --prefix frontend run build:test",
    "build:prod": "npm --prefix frontend run build:prod",
    "preview:dev": "npm --prefix frontend run preview:dev",
    "preview:test": "npm --prefix frontend run preview:test",
    "preview:prod": "npm --prefix frontend run preview:prod"
  }
}
